{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash /home/vscode/.claude/hooks/on_stop.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash /home/vscode/.claude/hooks/on_pre_compact.sh"
          }
        ]
      }
    ]
  }
}